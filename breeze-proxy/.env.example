# Breeze API Credentials
BREEZE_API_KEY=your_breeze_api_key_here
BREEZE_API_SECRET=your_breeze_api_secret_here
BREEZE_PROXY_ADMIN_KEY=your_admin_key_here

# GCP / Vertex AI (preferred for Cloud Run -- uses service account, no API key needed)
GCP_PROJECT_ID=your_gcp_project_id_here
VERTEX_LOCATION=us-central1

# Gemini API key (fallback for local development when GCP_PROJECT_ID is not set)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_URL=your_supabase_url_here
